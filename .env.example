# Copie este arquivo para .env.local (frontend) e defina as variáveis do servidor
# no ambiente da API. NUNCA versione .env.local nem segredos.

# --- Frontend (Vite) ------------------------------------------------------
# Autenticação institucional (apenas chave ANÔNIMA pública — nunca service_role).
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_PUBLICA
# Base da API institucional consumida pelo frontend.
VITE_API_BASE_URL=http://localhost:8787/api/v1

# --- Backend / API (NÃO exponha ao navegador) -----------------------------
# Conexão do papel de APLICAÇÃO, SEM BYPASSRLS (ex.: app_api). As políticas RLS
# só são efetivas se este papel não ignorar RLS.
DATABASE_URL=postgres://app_api:senha@localhost:5432/sigla
# Verificação de token no servidor (mesmo projeto Supabase do frontend).
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=SUA_CHAVE_ANON_PUBLICA
# Porta/host/origem CORS da API (opcionais).
API_PORT=8787
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:3000

# --- Testes de integração (opcional) --------------------------------------
# Papel de aplicação (sem bypassrls) para asserções de RLS.
# DATABASE_URL=postgres://app_api:senha@localhost:5432/sigla_test
# Papel privilegiado para criar fixtures e executar funções nos testes.
# DATABASE_ADMIN_URL=postgres://postgres:senha@localhost:5432/sigla_test
